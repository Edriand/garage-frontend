# ── Backend API (CloudFormation output: ApiUrl) ───────────────────────────
NEXT_PUBLIC_API_URL=https://xxxx.execute-api.eu-west-1.amazonaws.com/prod

# ── Amazon Cognito (CloudFormation outputs) ───────────────────────────────
NEXT_PUBLIC_USER_POOL_ID=eu-west-1_xxxxxxxxx
NEXT_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── S3 assets (CloudFormation output: AssetsBucketName) ──────────────────
NEXT_PUBLIC_ASSETS_BUCKET=your-stack-name-assets-bucket
